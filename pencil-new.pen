                    },
                    {
                      "type": "text",
                      "id": "Dqls3",
                      "fill": "#4A4540",
                      "content": "천장·벽 상태, 면적, 특수 요청사항이 있으면 함께 알려주세요. 정확한 확인 후 견적이 가능합니다.",
                      "fontFamily": "Inter",
                      "fontSize": 13,
                      "fontWeight": "normal"
