# Firebase Client (NEXT_PUBLIC_* 는 브라우저에 노출됨)
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Firebase Admin (서버 전용 - Service Account 키)
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=

# Firebase 사용 시 true (미설정 시 Mock 데이터 사용)
NEXT_PUBLIC_USE_FIREBASE=false

# OpenAI (관리자 AI 작성, 서버 전용)
OPENAI_API_KEY=

# 문의 링크 (선택)
NEXT_PUBLIC_KAKAO_URL=https://open.kakao.com/o/여기에링크입력
NEXT_PUBLIC_INSTAGRAM_URL=https://instagram.com/계정아이디
